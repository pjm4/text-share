{
  "name": "Text Share PWA",
  "short_name": "TextShare",
  "start_url": "/text-share-pwa/",
  "scope": "/text-share-pwa/",
  "display": "standalone",
  "icons": [{ "src": "icon-192.png", "sizes": "192x192", "type": "image/png" }],
  "share_target": {
    "action": "/text-share-pwa/",
    "method": "GET",
    "params": { "title": "title", "text": "text", "url": "url" }
  }
}
